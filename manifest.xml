<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">

  <Id>12345678-1234-1234-1234-123456789012</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Terrazzini &amp; Partners</ProviderName>
  <DefaultLocale>it-IT</DefaultLocale>
  <DisplayName DefaultValue="Gestione Pratiche"/>
  <Description DefaultValue="Presa in carico e chiusura pratiche di consulenza"/>
  <IconUrl DefaultValue="https://viktor0470.github.io/gestione-pratiche/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://viktor0470.github.io/gestione-pratiche/icon-128.png"/>
  <SupportUrl DefaultValue="https://viktor0470.github.io"/>
  <AppDomains>
    <AppDomain>https://viktor0470.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://viktor0470.github.io/gestione-pratiche/prendi-in-carico.html"/>
        <RequestedHeight>350</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="btnPrendiInCarico">
                  <Label resid="PrendiInCaricoLabel"/>
                  <Supertip>
                    <Title resid="PrendiInCaricoLabel"/>
                    <Description resid="PrendiInCaricoDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>PrendiInCarico</TaskpaneId>
                    <SourceLocation resid="PrendiInCarico.Url"/>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="btnChiudiPratica">
                  <Label resid="ChiudiLabel"/>
                  <Supertip>
                    <Title resid="ChiudiLabel"/>
                    <Description resid="ChiudiDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ChiudiPratica</TaskpaneId>
                    <SourceLocation resid="ChiudiPratica.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://viktor0470.github.io/gestione-pratiche/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://viktor0470.github.io/gestione-pratiche/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://viktor0470.github.io/gestione-pratiche/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://viktor0470.github.io/gestione-pratiche/commands.html"/>
        <bt:Url id="PrendiInCarico.Url" DefaultValue="https://viktor0470.github.io/gestione-pratiche/prendi-in-carico.html"/>
        <bt:Url id="ChiudiPratica.Url" DefaultValue="https://viktor0470.github.io/gestione-pratiche/chiudi-pratica.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Pratiche"/>
        <bt:String id="PrendiInCaricoLabel" DefaultValue="Prendi in Carico"/>
        <bt:String id="ChiudiLabel" DefaultValue="Chiudi Pratica"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="PrendiInCaricoDesc" DefaultValue="Prendi in carico questa pratica e compila i dati"/>
        <bt:String id="ChiudiDesc" DefaultValue="Chiudi la pratica e inserisci i dati di fatturazione"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
